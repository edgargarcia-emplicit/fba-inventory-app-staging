# =====================================================================
# SECRETS TEMPLATE — do NOT put real values in this file or in GitHub.
# On Streamlit Community Cloud: paste the filled-in version into
#   App → Settings → Secrets
# For running on your own computer: copy this file to
#   .streamlit/secrets.toml  (that filename is gitignored)
# =====================================================================

# The password your team types to open the app
app_password = "CHANGE-ME"

# The ID of the "FBA App Data" Google Sheet (from its URL) where the app
# stores clients, settings, notes, shipments, DOI history, health reports,
# case packs, and Prime Day config. The service account needs EDITOR
# access to this one sheet.
app_data_sheet_id = "PASTE-SHEET-ID-HERE"

# Paste the entire contents of your service account JSON key below.
# Every field comes straight from the JSON file you already have.
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "..."
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "your-service-account@your-project.iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."

# ---------------------------------------------------------------------
# OPTIONAL — only needed if you want the "Send now" button on the
# Digest Preview page to actually email people. Skip this section
# entirely if you just want to download/preview the digest for now.
#
# Easiest free option: a Gmail account + an "App Password" (not your
# normal Gmail password — Google Account → Security → 2-Step Verification
# → App Passwords → generate one for "Mail").
# ---------------------------------------------------------------------
# [smtp]
# host = "smtp.gmail.com"
# port = 587
# username = "youragencyemail@gmail.com"
# password = "your-16-character-app-password"
# from_address = "youragencyemail@gmail.com"
